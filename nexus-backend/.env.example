# =============================================================================
# Nexus Learning & Portfolio - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Required variables must be set or the application will fail to start.
# =============================================================================

# --- Required ---

# Platform mode: "tracker" (Phase 1 local) or "portfolio" (Phase 2 public)
NEXUS_MODE=tracker

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexus_db

# Secret key for JWT signing (use a strong random value)
JWT_SECRET=change-me-to-a-strong-random-secret

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# --- Optional ---

# JWT token lifetime in minutes (default: 60)
# JWT_EXPIRY_MINUTES=60

# Storage backend: "local" or "cloud" (default: local)
# STORAGE_BACKEND=local

# Local filesystem path for file uploads (used when STORAGE_BACKEND=local)
# STORAGE_LOCAL_PATH=./uploads

# Cloud storage configuration (required when STORAGE_BACKEND=cloud)
# CLOUD_STORAGE_BUCKET=my-nexus-bucket
# CLOUD_STORAGE_REGION=us-east-1
# CLOUD_STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
# CLOUD_STORAGE_ACCESS_KEY=your-access-key
# CLOUD_STORAGE_SECRET_KEY=your-secret-key

# LLM provider: "openai" or "anthropic" (required for About Me Bot)
# LLM_PROVIDER=openai

# OpenAI configuration (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic configuration (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Outbound webhook target URL
# WEBHOOK_URL=https://example.com/webhook

# Auth header value for webhook requests
# WEBHOOK_AUTH_HEADER=Bearer your-webhook-token
